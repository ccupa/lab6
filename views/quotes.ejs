<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
</head>

<body>
    <div class="page-wrap">
        <div class="main-card">
            <h1 class="page-title">Famous Quotes</h1>

            <nav class="mb-4">
                <a href="/" class="btn btn-outline-primary">Home</a>
            </nav>

            <% for (let i of rows) { %>
                <div class="quote-card">
                    <p class="quote-text">"<%= i.quote %>"</p>
                    <p class="quote-author">
                        - <a href="#" class="authorNames" data-author-id="<%= i.authorId %>">
                            <%= i.firstName %>
                                <%= i.lastName %>
                        </a>
                    </p>
                </div>
                <% } %>

                    <div id="authorModal" style="display:none; border:1px solid black; padding:20px; background:white;">
                        <div id="authorInfo">
                            <button id="closeModal">Close</button>
                            <h1 id="authorName"></h1>
                            <img id="authorPicture" width="300" alt="Author picture">
                            <div id="authorDetails"></div>
                        </div>
                    </div>

                    <footer>
                        <%- include("partials/footer.ejs") %>
                    </footer>
        </div>
    </div>

    <script src="/js/quotes.js"></script>
</body>

</html>