<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head.ejs") %>
</head>

<body>
    <div class="page-wrap">
        <div class="main-card">
            <h1 class="page-title">Quote Finder</h1>

            <div>
                <form action="/searchByKeyword" method="GET" class="search-form">
                    <label class="form-label-text">Search by Keyword</label>
                    <% if (errorMsg) { %>
                        <p style="color:red;"><%= errorMsg %></p>
                    <% } %>
                    <input type="text" name="keyword" class="form-control mb-3" placeholder="Enter a keyword">
                    <button class="btn btn-primary">Search by Keyword</button>
                </form>
            </div>
            <hr>

            <form action="/searchByAuthor" method="GET" class="search-form">
                <label class="form-label-text">Search by Author</label>
                <select name="authorId" class="form-select mb-3">
                    <% for (let i of authors) { %>
                        <option value="<%= i.authorId %>">
                            <%= i.firstName %> <%= i.lastName %>
                        </option>
                    <% } %>
                </select>
                <button class="btn btn-primary">Search by Author</button>
            </form>
            <hr>

            <form action="/searchByCategory" method="GET" class="search-form">
                <label for="category" class="form-label-text">Search by Category</label>
                <select name="category" id="category" class="form-select mb-3">
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.category %>">
                            <%= cat.category %>
                        </option>
                    <% }) %>
                </select>
                <button type="submit" class="btn btn-primary">Search by Category</button>
            </form>
            <hr>

            <form action="/searchByLikes" method="GET" class="search-form">
                <label for="startNum" class="form-label-text">Min Likes:</label>
                <input type="number" name="startNum" id="startNum" class="form-control mb-3">

                <label for="endNum" class="form-label-text">Max Likes:</label>
                <input type="number" name="endNum" id="endNum" class="form-control mb-3">

                <button type="submit" class="btn btn-primary">Search by Likes</button>
            </form>
            

            <footer>
                <%- include("partials/footer.ejs") %>
            </footer>
        </div>
    </div>
</body>

</html>